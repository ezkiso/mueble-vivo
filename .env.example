# ─── Supabase (Postgres) ───────────────────────────────
# Connection pooling (pgbouncer, puerto 6543) - usar en runtime
DATABASE_URL="postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:6543/postgres?pgbouncer=true"
# Conexión directa (puerto 5432) - usada solo por `prisma db push`/migrate
DIRECT_URL="postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres"

# ─── JWT / Sesión admin ────────────────────────────────
# Generar con: openssl rand -base64 48
JWT_SECRET="CAMBIAR_POR_UN_SECRETO_LARGO_Y_ALEATORIO"
JWT_EXPIRES_IN="20m"

# ─── CSRF ───────────────────────────────────────────────
CSRF_SECRET="CAMBIAR_POR_OTRO_SECRETO_ALEATORIO"

# ─── Cloudinary (25GB / 25 créditos free tier) ─────────
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# ─── Transbank Webpay Plus ──────────────────────────────
TRANSBANK_ENVIRONMENT="INTEGRACION"   # INTEGRACION | PRODUCCION
# En INTEGRACION, transbank-sdk usa credenciales de prueba públicas automáticamente.
# Para PRODUCCION, completar con las credenciales reales entregadas por Transbank:
TRANSBANK_COMMERCE_CODE=""
TRANSBANK_API_KEY=""

# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NODE_ENV="development"
