// Esquema de base de datos - Mueble Vivo
// Ejecutar: npx prisma db push  (Supabase Postgres, plan gratuito)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
  FAILED
  OVERSOLD
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Int
  stock       Int      @default(0)
  images      Json     @default("[]")
  salesCount  Int      @default(0)
  active      Boolean  @default(true)
  sold        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
  comments   Comment[]

  @@index([createdAt])
  @@index([salesCount])
}

model Order {
  id               String      @id @default(cuid())
  customerName     String
  customerEmail    String
  customerPhone    String
  shippingAddress  String
  shippingLat      Float
  shippingLng      Float
  totalAmount      Int
  status           OrderStatus @default(PENDING)
  buyOrder         String      @unique
  sessionId        String
  transactionToken String?
  transactionId    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  items           OrderItem[]
  buyerCredential BuyerCredential?

  @@index([status])
  @@index([buyOrder])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Admin {
  id             String    @id @default(cuid())
  username       String    @unique
  passwordHash   String
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
}

model SecurityLog {
  id        String   @id @default(cuid())
  event     String
  ip        String?
  detail    String?
  createdAt DateTime @default(now())
}

model EjemploPersonalizado {
  id          String   @id @default(cuid())
  imageUrl    String
  description String
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
}

model BuyerCredential {
  id             String   @id @default(cuid())
  orderId        String   @unique
  tokenHash      String   @unique
  tokenEncrypted String
  customerName   String
  revealed       Boolean  @default(false)
  revoked        Boolean  @default(false)
  createdAt      DateTime @default(now())

  order    Order     @relation(fields: [orderId], references: [id])
  comments Comment[]

  @@index([orderId])
}

model Comment {
  id        String        @id @default(cuid())
  productId String
  buyerId   String
  body      String
  images    Json          @default("[]")
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  product Product         @relation(fields: [productId], references: [id])
  buyer   BuyerCredential @relation(fields: [buyerId], references: [id])

  @@index([productId, status])
  @@index([buyerId])
}